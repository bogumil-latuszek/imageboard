@page
@using Microsoft.AspNetCore.StaticFiles
@using imageboard.Models
@model imageboard.Pages.ItemDetails

<!DOCTYPE html>

<html>
<head>
    <title></title>
</head>
<body>
    <div class="container">
        @if (@Model.item != null)
        {
            @if (Model.IsVideoExtension(Model.item.FileType))
            {
                <video controls style="max-width: 100%;">
                    <source src="@Model.getItemURL(Model.item.Id, Model.item.FileType)" 
                            type=@($"video/{Model.item.FileType}")>
                    Your browser does not support the video tag.
                </video>
            }
            else
            {
                <img src="@Model.getItemURL(Model.item.Id, Model.item.FileType)"
                    alt="@Model.item.Id" 
                    style="max-width: 100%;" />
            }

            <section>
                <h2>Description</h2>
                <div class="card">
                    <div class="card-body">
                        <p class="card-text text-muted small">@Model.item.Description</p>
                    </div>
                </div>
            </section>

            <section>
                <h2>Tags</h2>
                <div class="mb-2">
                    @foreach (var itemTag in Model.item.ItemTags)
                    {
                        <a href="/Gallery?search=@itemTag.Tag.Name" 
                        class="badge text-decoration-none me-1 fs-5" style="color: rgb(0, 101, 233); background-color:rgb(178, 209, 250);">
                            @itemTag.Tag.Name
                            <span style="color:rgb(0, 0, 0);">
                                @itemTag.Tag.UseCount
                            </span>
                        </a>
                    }
                </div>
            </section>

            @* <section>
                <h2>Additional Info</h2>
                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted">
                        <i class="bi-person">@Model.item.UploaderId</i> 
                    </small>
                    <small class="text-muted">
                        <i class="bi-calendar"> @Model.item.UploadDate.ToString("MMM dd") </i>
                    </small>
                </div>
            </section> *@

            <section>
                <h2>Additional Info</h2>
                <div class="d-flex flex-row bd-highlight">
                    <div class="p-2 bd-highlight">Uploader:</div>
                    <div class="p-2 bd-highlight">@Model.item.UploaderId</div>
                </div>
                <div class="d-flex flex-row bd-highlight">
                    <div class="p-2 bd-highlight">Upload Date:</div>
                    <div class="p-2 bd-highlight">@Model.item.UploadDate</div>
                </div>
            </section>

            <section>
                <!-- edit delete etc.-->
                <div class="d-flex flex-row bd-highlight">
                    
                    <div class="p-2 bd-highlight">
                        <!-- Delete button with confirmation popup -->
                        <!-- The onsubmit="return confirm('message')" triggers a browser confirmation dialog -->
                        <!-- If user clicks OK, confirm() returns true and the form submits -->
                        <!-- If user clicks Cancel, confirm() returns false and the form submission is cancelled -->
                        <form method="post" asp-page-handler="Delete" 
                            onsubmit="return confirm('Are you sure you want to delete this image? This action cannot be undone.');">
                            <input type="hidden" name="Id" value="@Model.item.Id" />
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </form>
                    </div>

                    <div class="p-2 bd-highlight">
                        <form method="edit" asp-page-handler="Edit" 
                            onsubmit="return confirm('Are you sure you want to delete this image? This action cannot be undone.');">
                            <button type="submit" class="btn btn-primary">Edit</button>
                        </form>
                    </div>

                </div>
            </section>
        }
        else
        {
            <div class="alert alert-warning">
                404 IMAGE NOT FOUND
            </div>
        }
    </div>
</body>
</html>