@page
@model imageboard.Pages.Gallery

@{
    ViewData["Title"] = "Image Gallery";
}

<div class="container">
    <h1 class="mb-4">Image Gallery</h1>
    
    <!-- Search Form -->
    <form method="get" class="mb-4">
        <div class="input-group">
            <input type="text" 
                   class="form-control" 
                   name="search" 
                   placeholder="Search by title, description, or tags..."
                   value="@Model.SearchTerm">
            <button class="btn btn-primary" type="submit">
                <i class="bi-search"></i> Search
            </button>
            @if (!string.IsNullOrEmpty(Model.SearchTerm))
            {
                <a href="/Gallery" class="btn btn-outline-secondary">Clear Search</a>
            }
        </div>
    </form>
    
    <!-- Search Results Summary -->
    @if (!string.IsNullOrEmpty(Model.SearchTerm))
    {
        <div class="alert alert-info">
            Found @Model.TotalItems images for "<strong>@Model.SearchTerm</strong>"
        </div>
    }
    
    <!-- Image Grid -->
    @if (Model.items.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
            @foreach (var item in Model.items)
            {
                bool isVideo = Model.IsVideoExtension(item.FileType);
                string imgSrc = isVideo ? @Model.getThumbnailURL(item.Id) : @Model.getItemURL(item.Id, item.FileType);
                            
                <div class="col">
                    <div class="card h-100 shadow-sm border-1 p-0">
                        <a asp-page="/itemDetails" asp-route-itemID="@item.Id" class="text-decoration-none">
                            <div class="card-img-top position-relative" 
                            style="height: 300px; overflow: hidden; background-color: #f8f9fa; border-radius: 0;">
                                <img src=@imgSrc 
                                class="img-fluid w-100 h-100" 
                                style="object-fit: contain;" 
                                alt="img-fluid">
                            </div>
                        </a>
                    </div>
                </div>
            }
        </div>
        
        <!-- Empty State for No Images -->
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi-images" style="font-size: 4rem; color: #dee2e6;"></i>
            <h3 class="mt-3">No images found</h3>
            <p class="text-muted">
                @if (string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <span>The gallery is empty. <a href="/Upload">Upload the first image!</a></span>
                }
                else
                {
                    <span>No images match your search. <a href="/Gallery">View all images</a></span>
                }
            </p>
        </div>
    }

    @if (!Model.items.Any())
    {
        <!-- Upload Call-to-Action -->
        <div class="text-center mt-5 py-5 border-top">
            <h3>No items yet? Be the first to upload!</h3>
            <p class="text-muted mb-4">Share your images and videos with the community.</p>
            <a asp-page="/Upload" class="btn btn-primary btn-lg">
                <i class="bi-cloud-upload"></i> Upload First Item
            </a>
        </div>
    }
</div>

